<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#907979"
    tools:context=".WelcomeActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/kl6g6nucgqoxzsgb7db2__0__1oxhs"
        tools:layout_editor_absoluteX="0dp"
        tools:layout_editor_absoluteY="-16dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="51dp"
            android:text="Welcome Bestie!"
            android:textColor="#22231E"
            android:textSize="40sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvSubTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hack &amp; Myth Wonders"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvTitle" />

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="281dp"
            android:layout_height="65dp"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="56dp"
            android:backgroundTint="#5E35B1"
            android:backgroundTintMode="add"
            android:drawableTint="#8A5B5B"
            android:ellipsize="middle"
            android:foregroundTint="#A87689"
            android:padding="@dimen/cardview_default_radius"
            android:shadowColor="#A67676"
            android:text="Welcome, myth-bestie! Test your ability to seperate real life-saving shortcuts from dangerous internet rumors."
            android:textAlignment="center"
            android:textSize="16sp"
            android:typeface="normal"
            android:verticalScrollbarPosition="defaultPosition"
            android:visibility="visible"
            app:layout_constraintBottom_toTopOf="@+id/tvDescription"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvSubTitle"
            app:layout_constraintVertical_bias="0.043" />

        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="412dp"
            android:layout_height="216dp"
            android:layout_marginBottom="128dp"
            android:backgroundTint="#901D1D"
            android:lineSpacingExtra="24sp"
            android:text="- Read each statement carefully.                                                - Decide: Hack (True) or Myth (False).                                                                              - Get instant feedback with the real explanation.                                                                             - Earn your final score and become a Master Hacker Bestie!"
            android:textAlignment="viewStart"
            android:textColor="#37273C"
            android:textSize="14sp"
            android:textStyle="bold"
            android:typeface="serif"
            app:layout_constraintBottom_toTopOf="@+id/btnStart"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.589"
            app:layout_constraintStart_toStartOf="parent" />

        <Button
            android:id="@+id/btnStart"
            android:layout_width="128dp"
            android:layout_height="53dp"
            android:layout_marginTop="508dp"
            android:backgroundTint="#926FD7"
            android:text="START"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.498"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSubTitle" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>